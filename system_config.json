{
  "system": "SkyBorn-Dream-or-Reality-",
  "environment": "production",
  "config_version": "1.0.0",
  "data_pipeline": {
    "enabled": true,
    "input_directory": "./assets",
    "output_directory": "./docs",
    "log_level": "info",
    "max_retries": 3
  },
  "sensors": {
    "atmospheric": {
      "enabled": true,
      "interval_seconds": 300,
      "parameters": ["PM2.5", "PM10", "O3", "NO2", "CO", "temperature", "humidity"]
    },
    "visual": {
      "enabled": true,
      "capture_interval_seconds": 900,
      "resolution": "1920x1080"
    }
  },
  "alerts": {
    "air_quality_threshold": 150,
    "notify_on_breach": true,
    "notification_channel": "log"
  },
  "repository": {
    "remote": "https://github.com/desertsmogtech/SkyBorn-Dream-or-Reality-.git",
    "branch": "main",
    "auto_push": false
  }
}
