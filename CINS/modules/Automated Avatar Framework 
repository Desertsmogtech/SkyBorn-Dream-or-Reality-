import json
import websockets

async def handler(websocket):
    async for message in websocket:
        data = json.loads(message)
        print("[SERVER] Received:", data)
        # Echo with simple ack
        await websocket.send(json.dumps({"type": "ACK", "received": data}))

async def main():
    async with websockets.serve(handler, "localhost", 8765):
        print("[SERVER] WebSocket server running on ws://localhost:8765")
        await asyncio.Future()  # run forever

if __name__ == "__main__":
    asyncio.run(main())import asyncio
from core.memory import Memory
from core.decision_engine import DecisionEngine
from core.arbitration import arbitrate

from agents.scanner import ScannerAgent
from agents.crypto import CryptoAgent
from agents.guard import GuardAgent
from agents.adapt import AdaptAgent
from agents.comms import CommsAgent


async def avatar_loop():
    memory = Memory()
    decision_engine = DecisionEngine()

    scanner = ScannerAgent()
    crypto = CryptoAgent()
    guard = GuardAgent()
    adapt = AdaptAgent()
    comms = CommsAgent("ws://localhost:8765")

    await comms.connect()
    print("[AVATAR] Connected to WebSocket server")

    malicious_threshold = memory.LTM["learned_params"]["malicious_threshold"]

    while True:
        state = memory.get_state()

        # 1) Perception: scanner proposes a new signal
        scan_proposal = scanner.propose(state)
        signal = scan_proposal["payload"]
        memory.add_signal(signal)
        print("[AVATAR] New signal:", signal)

        # 2) Decision: classify signal
        action_label = decision_engine.decide(signal, malicious_threshold)
        decision = {"signal": signal, "decision": action_label}
        memory.add_decision(decision)
        print("[AVATAR] Decision:", action_label)

        # 3) Other agents propose
        state = memory.get_state()
        crypto_prop = crypto.propose(state)
        adapt_prop = adapt.propose(state)

        proposals = [scan_proposal, crypto_prop, adapt_prop]
        final_action = arbitrate(proposals)

        print("[AVATAR] Arbitration chose:", final_action)

        # 4) Governance
        if guard.allows(final_action):
            outbound = {
                "type": "AVATAR_ACTION",
                "decision": action_label,
                "agent_action": final_action,
            }
            await comms.send(outbound)
            print("[AVATAR] Sent to server.")
        else:
            print("[AVATAR] Action blocked by GuardAgent.")

        # 5) Apply adaptation
        if final_action and final_action["action"] == "UPDATE_THRESHOLD":
            malicious_threshold = final_action["payload"]["malicious_threshold"]
            memory.LTM["learned_params"]["malicious_threshold"] = malicious_threshold
            print("[AVATAR] Updated malicious_threshold:", malicious_threshold)

        await asyncio.sleep(1.0)


if __name__ == "__main__":
    asyncio.run(avatar_loop())